# ─────────────────────────────────────────
# Supabase（数据库 + 用户认证）
# 注册地址: https://supabase.com
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─────────────────────────────────────────
# OpenAI
# 注册地址: https://platform.openai.com
# ─────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ─────────────────────────────────────────
# Google Maps Platform
# 注册地址: https://console.cloud.google.com
# 需要开启: Maps JavaScript API, Places API (New), Geocoding API
# 每月 $200 免费额度
# ─────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─────────────────────────────────────────
# Serper（Google 图片搜索 — 用于菜式照片）
# 注册地址: https://serper.dev
# 免费额度: 每月 2,500 次
# ─────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key

# ─────────────────────────────────────────
# Google Custom Search（菜式照片备用源，可选）
# 注册地址: https://console.cloud.google.com
# ─────────────────────────────────────────
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_google_cse_id

# ─────────────────────────────────────────
# Pexels（菜式照片备用源，可选）
# 注册地址: https://www.pexels.com/api/
# ─────────────────────────────────────────
PEXELS_API_KEY=your_pexels_api_key

# ─────────────────────────────────────────
# 应用配置
# 生产环境设置为 Cloud Run URL，例如：
#   https://foodie-buddy-xxxxx.run.app
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
